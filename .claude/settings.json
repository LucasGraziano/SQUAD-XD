{
  "language": "portuguese",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"DICA DE INICIO DE SESSAO: O usuario pode rodar /atlas-briefing (status operacional), /recall (retomar contexto) ou seguir com o pedido. NAO execute comandos automaticamente. Se o usuario invocou um agente especifico (@aios-master, @dev, @qa, etc.), respeite a persona convocada — nao assine como Atlas se o agente ativo for outro.\"}}'",
            "once": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"REVIEW REMINDER: Antes de encerrar, pergunte ao usuario se quer rodar /review-day para fechar a sessao e registrar o progresso no Notion.\"}'",
            "statusMessage": "Verificando fechamento de sessao..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".aiox-core/core/hooks/check-design-md.js\"",
            "statusMessage": "Verificando DESIGN.md..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let b='';process.stdin.on('data',c=>b+=c);process.stdin.on('end',()=>{try{const d=JSON.parse(b);const f=d.tool_input?.file_path||d.tool_response?.filePath||'';if(f.endsWith('.json')){try{JSON.parse(require('fs').readFileSync(f,'utf8'));console.log(JSON.stringify({suppressOutput:true}))}catch(e){console.log(JSON.stringify({systemMessage:'JSON invalido em '+f+': '+e.message}))}}else{console.log(JSON.stringify({suppressOutput:true}))}}catch(e){console.log(JSON.stringify({suppressOutput:true}))}})\"",
            "statusMessage": "Validando arquivo..."
          }
        ]
      }
    ]
  }
}

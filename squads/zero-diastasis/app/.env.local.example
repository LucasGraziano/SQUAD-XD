# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook — required for payment events (Hotmart/LastLink)
WEBHOOK_SECRET=your-webhook-secret-from-payment-provider

# CDN — optional (if empty, falls back to /public/ directory)
# Set to your CDN base URL, e.g. https://cdn.yourdomain.com
NEXT_PUBLIC_AUDIO_CDN_URL=
NEXT_PUBLIC_BONUS_CDN_URL=

# Checkout URLs — set after Hotmart/LastLink products are created
NEXT_PUBLIC_CHECKOUT_URL_PACK_RECEITAS=
NEXT_PUBLIC_CHECKOUT_URL_ACELERACION=
NEXT_PUBLIC_CHECKOUT_URL_RESET_POSTURAL=
NEXT_PUBLIC_CHECKOUT_URL_MANTENIMIENTO=
NEXT_PUBLIC_CHECKOUT_URL_COMUNIDAD=
NEXT_PUBLIC_CHECKOUT_URL_CONSULTA=

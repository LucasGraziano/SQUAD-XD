# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Story 0.2+)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@luckysaas.com.br

# ZapSign (Story 6.x)
ZAPSIGN_API_TOKEN=your-token

# Analytics (opcional)
NEXT_PUBLIC_VERCEL_ANALYTICS=true

# PostHog (Story 6.2+)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Web Push / PWA (Story 6.6)
# Gerar com: node -e "const webpush=require('web-push'); console.log(JSON.stringify(webpush.generateVAPIDKeys()))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:suporte@premia.app

# ── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # nunca expor no frontend

# ── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://vinculo.app         # ou http://localhost:3001 em dev

# ── Resend (e-mail transacional) ─────────────────────────
RESEND_API_KEY=re_<key>
RESEND_FROM_EMAIL=noreply@vinculo.app

# ── Z-API (WhatsApp Business) ───────────────────────────
# Obter em: https://z-api.io → sua instância → Configurações
ZAPI_INSTANCE_ID=<instance-id>
ZAPI_TOKEN=<token>
ZAPI_CLIENT_TOKEN=<client-token>

# ── Cron Jobs ───────────────────────────────────────────
# Header: Authorization: Bearer <CRON_SECRET>
# Configurar no Vercel Cron ou Supabase Edge Function scheduler
CRON_SECRET=<random-secret-min-32-chars>
